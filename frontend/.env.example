# Backend API base URL — include trailing /api
VITE_API_URL=http://localhost:5000/api

# GitHub username used by the public projects carousel on the homepage
VITE_GITHUB_USERNAME=Veenbreeze

# Optional Google OAuth client (only needed for the in-page Google SDK; the
# default OAuth flow goes through the backend and does not require this).
VITE_GOOGLE_CLIENT_ID=
