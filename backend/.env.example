# ---- Server ----
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# ---- Auth ----
JWT_SECRET=replace-with-a-long-random-secret

# ---- PostgreSQL (choose one) ----
# Option A: single connection URL (preferred)
# DATABASE_URL=postgres://user:password@localhost:5432/veenbreeze

# Option B: individual variables
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=veenbreeze

# ---- OAuth (optional) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- Seed admin (optional) ----
SEED_ADMIN_EMAIL=admin@veenbreeze.com
SEED_ADMIN_PASSWORD=AdminPass123
SEED_ADMIN_NAME=Veenbreeze Admin
